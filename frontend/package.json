{
  "name": "myuni-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0 --port 5173",
    "build": "node scripts/build-production.mjs",
    "build:spa": "vite build",
    "build:prerender": "vite build && node scripts/prerender-public.mjs",
    "preview": "vite preview",
    "prerender": "node scripts/prerender-public.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "cleanup:test-users": "cd ../backend && .venv\\Scripts\\python.exe manage.py purge_test_accounts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@vitejs/plugin-react": "6.0.2",
    "axios": "1.16.1",
    "@sentry/react": "^9.47.1",
    "framer-motion": "12.40.0",
    "leaflet": "^1.9.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "7.15.1",
    "vite": "8.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "autoprefixer": "10.5.0",
    "eslint": "10.4.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "jsdom": "^28.1.0",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.19",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.18"
  }
}
