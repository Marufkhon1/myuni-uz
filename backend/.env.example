# Kamida 32 belgi (production majburiy)
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,myuni.uz,www.myuni.uz
# Mahalliy Wi‑Fi: boshqa telefon/kompyuter uchun True qiling
DJANGO_ALLOW_LAN=False
SERVE_MEDIA=True
SECURE_SSL_REDIRECT=False
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myuni
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback/

# Email: haqiqiy xat uchun SMTP to'ldiring (Gmail: App Password kerak)
# EMAIL_BACKEND bo'sh qoldirilsa va EMAIL_HOST bor bo'lsa — avtomatik SMTP ishlatiladi
EMAIL_BACKEND=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your@gmail.com
# Dev: SMTP bo'lmasa xatlarni faylga yozish (backend/sent_emails/)
# EMAIL_USE_FILE=True
# Parol tiklash cheklovi (ixtiyoriy)
# PASSWORD_RESET_EMAIL_COOLDOWN=120
# PASSWORD_RESET_MAX_PER_EMAIL_HOUR=3
# PASSWORD_RESET_MAX_PER_SESSION_HOUR=5
# Sharh moderatsiyasi: True bo'lsa yangi sharhlar pending, admin tasdiqlaydi
# REVIEW_MODERATION_ENABLED=False
# REVIEW_MODERATOR_EMAILS=moderator@myuni.uz

# Sharh yuborish cheklovi (ixtiyoriy)
# REVIEW_SUBMIT_FREE_ATTEMPTS=3
# REVIEW_SUBMIT_COOLDOWN=300
# REVIEW_SUBMIT_MIN_INTERVAL=45
# REVIEW_SUBMIT_MAX_PER_USER_HOUR=8

# Qo'llab-quvvatlash chat → Telegram (ixtiyoriy)
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_CHAT_ID=

# Qo'llab-quvvatlash formasi rate limit (ixtiyoriy)
# SUPPORT_MAX_PER_IP_HOUR=10
# SUPPORT_MAX_PER_SESSION_HOUR=5

# SSE qisqa muddatli token (sekund)
# STREAM_TOKEN_TTL_SECONDS=300

# JWT httpOnly cookie (login/register avtomatik)
# JWT_ACCESS_COOKIE_MAX_AGE=3600
# JWT_REFRESH_COOKIE_MAX_AGE=604800
