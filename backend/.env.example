# Kamida 32 belgi (production majburiy)
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,myuni.uz,www.myuni.uz
# Mahalliy Wi‑Fi: boshqa telefon/kompyuter uchun True qiling
DJANGO_ALLOW_LAN=False
SERVE_MEDIA=True
SECURE_SSL_REDIRECT=False
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myuni
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Ixtiyoriy: FRONTEND_ORIGIN / FRONTEND_URL ga qo‘shimcha CSRF trusted origins
# CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback/

# Email: haqiqiy xat uchun SMTP to'ldiring (Gmail: App Password kerak)
# EMAIL_BACKEND bo'sh qoldirilsa va EMAIL_HOST bor bo'lsa — avtomatik SMTP ishlatiladi
EMAIL_BACKEND=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your@gmail.com
# Dev: SMTP bo'lmasa xatlarni faylga yozish (backend/sent_emails/)
# EMAIL_USE_FILE=True
# Parol tiklash cheklovi (ixtiyoriy)
# PASSWORD_RESET_EMAIL_COOLDOWN=120
# PASSWORD_RESET_MAX_PER_EMAIL_HOUR=3
# PASSWORD_RESET_MAX_PER_SESSION_HOUR=5
# Sharh moderatsiyasi: True bo'lsa yangi sharhlar pending, admin tasdiqlaydi
# REVIEW_MODERATION_ENABLED=False
# REVIEW_MODERATOR_EMAILS=moderator@myuni.uz

# Sharh yuborish cheklovi (ixtiyoriy)
# REVIEW_SUBMIT_FREE_ATTEMPTS=3
# REVIEW_SUBMIT_COOLDOWN=300
# REVIEW_SUBMIT_MIN_INTERVAL=45
# REVIEW_SUBMIT_MAX_PER_USER_HOUR=8

# Qo'llab-quvvatlash chat → Telegram (ixtiyoriy)
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_CHAT_ID=

# Qo'llab-quvvatlash formasi rate limit (ixtiyoriy)
# SUPPORT_MAX_PER_IP_HOUR=10
# SUPPORT_MAX_PER_SESSION_HOUR=5

# SSE qisqa muddatli token (sekund)
# STREAM_TOKEN_TTL_SECONDS=300

# Web Push (G5 — PWA bildirishnomalar; bo'sh qoldirilsa push o'chiriladi)
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_VAPID_SUBJECT=mailto:hello@myuni.uz

# JWT httpOnly cookie (login/register avtomatik)
# JWT_ACCESS_COOKIE_MAX_AGE=3600
# JWT_REFRESH_COOKIE_MAX_AGE=604800
# AUTH_RETURN_TOKENS_IN_BODY=False
# AUTH_LOGIN_MAX_PER_IP_HOUR=40
# AUTH_LOGIN_FAILURE_THRESHOLD=5
# AUTH_REGISTER_MAX_PER_IP_HOUR=15
# AUTH_GOOGLE_START_MAX_PER_IP_HOUR=30
# AUTH_GOOGLE_CALLBACK_MAX_PER_IP_HOUR=20
# AUTH_EXCHANGE_CODE_TTL_SECONDS=120

# Redis — production (DJANGO_DEBUG=False) da MAJBURIY.
# Cache, auth rate-limit, SSE stream token, Channels (WebSocket), public API response cache.
# REDIS_URL=redis://127.0.0.1:6379/0
# Dev: bo'sh qoldirilsa LocMem + InMemory Channels.
# REDIS_IGNORE_EXCEPTIONS=True   # faqat DEBUG; prod default False (fail-closed)
# REDIS_SKIP_PING=True           # faqat CI / booting tests; prodda o'chiring

# Public /api/public/* — throttle (anon IP) + response cache TTL (sekund)
# PUBLIC_THROTTLE_RATE=300/hour
# PUBLIC_HEAVY_THROTTLE_RATE=120/hour
# PUBLIC_STATS_THROTTLE_RATE=60/hour
# PUBLIC_API_CACHE_ENABLED=True
# PUBLIC_CACHE_TTL_STATS=300
# PUBLIC_CACHE_TTL_LANDING=120
# PUBLIC_CACHE_TTL_CATALOG=180
# PUBLIC_CACHE_TTL_DETAIL=180
# PUBLIC_CACHE_TTL_COMPARE=300
# PUBLIC_CACHE_TTL_SITEMAP=3600
# PUBLIC_CACHE_BROWSER_MAX_AGE=60

# Error monitoring (Sentry)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# API hujjatlari (Swagger) — production: ENABLE_API_DOCS=True
# ENABLE_API_DOCS=False
